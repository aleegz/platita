{
  "expo": {
    "name": "Platita",
    "slug": "platita",
    "version": "0.1.0",
    "scheme": "platita",
    "icon": "./assets/app-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1115",
          "resizeMode": "contain",
          "image": "./assets/splash_screen.png",
          "imageWidth": 320,
          "android": {
            "backgroundColor": "#0F1115",
            "image": "./assets/splash_screen.png",
            "imageWidth": 320,
            "resizeMode": "contain"
          },
          "ios": {
            "backgroundColor": "#0F1115",
            "image": "./assets/splash_screen.png",
            "imageWidth": 320,
            "resizeMode": "contain"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "icon": "./assets/app-icon.png"
    },
    "android": {
      "package": "com.aleegz.platita",
      "icon": "./assets/app-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png",
        "backgroundColor": "#0F1115"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "9d36f590-d006-48ef-8766-5ea425890146"
      }
    }
  }
}
